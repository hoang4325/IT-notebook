<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Toolbar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back"
                    app:tint="@color/colorTextPrimary"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/formula_detail"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <ImageView
                    android:id="@+id/btnEdit"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_edit"
                    android:contentDescription="Edit"
                    app:tint="@color/colorTextPrimary"
                    android:padding="4dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <ImageView
                    android:id="@+id/btnDelete"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_delete"
                    android:contentDescription="Delete"
                    app:tint="@color/topic_red"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <!-- Title with Favorite -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Formula Title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="26sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/btnFavorite"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_star_outline"
                    android:contentDescription="Favorite"
                    app:tint="@color/colorIconInactive"
                    android:padding="4dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <!-- Tags -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="10dp"/>

            <!-- Code Block with Terminal Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_code_block">

                <!-- Terminal Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:background="@color/colorSurfaceCode">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LOGIC"
                        android:textColor="@color/colorIconInactive"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15"/>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@color/topic_red"/>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@color/topic_orange"/>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@color/topic_green"/>
                </LinearLayout>

                <!-- Code Content -->
                <TextView
                    android:id="@+id/tvContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/colorTextCode"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:background="@color/colorSurface"/>
            </LinearLayout>

            <!-- Explanation Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:text="Explanation"
                android:textColor="@color/primary_light"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <!-- Examples Section -->
            <TextView
                android:id="@+id/tvExamplesLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:text="Examples"
                android:textColor="@color/primary_light"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvExamples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- AI EXPLAIN SECTION                                              -->
            <!-- ═══════════════════════════════════════════════════════════════ -->

            <!-- Hàng nút AI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <!-- Nút AI Giải thích -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAiExplain"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="✦ AI Giải thích"
                    android:textSize="12sp"
                    android:textColor="#A78BFA"
                    android:paddingHorizontal="8dp"
                    app:icon="@null"
                    app:strokeColor="#7C3AED"
                    app:strokeWidth="1dp"
                    app:cornerRadius="22dp"/>

                <!-- Nút Dịch Code -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTranslateCode"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="⇄ Dịch Code"
                    android:textSize="12sp"
                    android:textColor="#38BDF8"
                    android:paddingHorizontal="8dp"
                    app:icon="@null"
                    app:strokeColor="#0EA5E9"
                    app:strokeWidth="1dp"
                    app:cornerRadius="22dp"/>

                <!-- Nút Phỏng vấn AI -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInterview"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="🎤 Phỏng vấn"
                    android:textSize="12sp"
                    android:textColor="#FCD34D"
                    android:paddingHorizontal="8dp"
                    app:icon="@null"
                    app:strokeColor="#F59E0B"
                    app:strokeWidth="1dp"
                    app:cornerRadius="22dp"/>

            </LinearLayout>

            <!-- Card kết quả AI (ẩn mặc định) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAiResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="100dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1A0D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header card AI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="✦ AI Analysis"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>

                        <!-- Nút lưu AI vào DB -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveAiExplanation"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Lưu vào ghi chú"
                            android:textSize="11sp"
                            android:textColor="#7C3AED"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Loading indicator -->
                    <LinearLayout
                        android:id="@+id/layoutAiLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:indeterminateTint="#A78BFA"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gemini đang phân tích code..."
                            android:textColor="#7B7F9E"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Nội dung Markdown AI -->
                    <TextView
                        android:id="@+id/tvAiResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#D1D5DB"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:visibility="gone"/>

                    <!-- Lỗi AI -->
                    <TextView
                        android:id="@+id/tvAiError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#F87171"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!-- CODE TRANSLATOR SECTION                                         -->
            <!-- ════════════════════════════════════════════════════════════════ -->

            <!-- Card kết quả dịch code (ẩn mặc định) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTranslateResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="100dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0A1929"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header: tiêu đề + chọn ngôn ngữ target -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvTranslateHeader"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⇄ Dịch sang Python"
                            android:textColor="#38BDF8"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>

                        <!-- Nút copy kết quả -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyTranslated"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Copy"
                            android:textSize="11sp"
                            android:textColor="#0EA5E9"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- Loading -->
                    <LinearLayout
                        android:id="@+id/layoutTranslateLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:indeterminateTint="#38BDF8"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:id="@+id/tvTranslateLoadingText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang dịch sang Python..."
                            android:textColor="#7B7F9E"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <!-- Kết quả code đã dịch -->
                    <TextView
                        android:id="@+id/tvTranslatedCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="#BAE6FD"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:visibility="gone"/>

                    <!-- Lỗi dịch -->
                    <TextView
                        android:id="@+id/tvTranslateError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#F87171"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- INTERVIEW CARD (ẩn mặc định)                                   -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInterview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#0D1F12"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvInterviewHeader"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Chế độ Phỏng vấn"
                            android:textColor="#FCD34D"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvInterviewPhase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang tạo câu hỏi..."
                            android:textColor="#7B7F9E"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Loading câu hỏi -->
                    <LinearLayout
                        android:id="@+id/layoutInterviewLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="visible">

                        <ProgressBar
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:indeterminateTint="#FCD34D"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI đang chuẩn bị câu hỏi..."
                            android:textColor="#7B7F9E"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Câu hỏi (streaming) -->
                    <TextView
                        android:id="@+id/tvInterviewQuestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FDE68A"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:visibility="gone"/>

                    <!-- Divider -->
                    <View
                        android:id="@+id/dividerAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2D3A1F"
                        android:layout_marginVertical="14dp"
                        android:visibility="gone"/>

                    <!-- Label câu trả lời -->
                    <TextView
                        android:id="@+id/tvAnswerLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✍️ Câu trả lời của bạn:"
                        android:textColor="#86EFAC"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"/>

                    <!-- Input câu trả lời -->
                    <EditText
                        android:id="@+id/etUserAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:maxLines="6"
                        android:hint="Nhập câu trả lời của bạn tại đây..."
                        android:textColorHint="#3A4A2F"
                        android:textColor="#D1FAE5"
                        android:textSize="13sp"
                        android:background="@null"
                        android:paddingVertical="8dp"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:visibility="gone"/>

                    <!-- Nút nộp bài -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="10dp"
                        android:text="📝 Nộp bài &amp; Chấm điểm"
                        android:textColor="#1A1A2E"
                        android:textSize="13sp"
                        app:backgroundTint="#FCD34D"
                        app:cornerRadius="10dp"
                        android:visibility="gone"/>

                    <!-- Kết quả chấm điểm -->
                    <TextView
                        android:id="@+id/tvGradeResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="#D1FAE5"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:visibility="gone"/>

                    <!-- Lỗi -->
                    <TextView
                        android:id="@+id/tvInterviewError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#F87171"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <!-- Fixed Bottom Copy Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCopy"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="Copy Formula"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:icon="@drawable/ic_copy"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primary"
        app:cornerRadius="14dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
